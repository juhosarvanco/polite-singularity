---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  titleAccent?: string;
  subtitle?: string;
  description: string;
  date: Date;
  category: string;
  readingTime?: string;
  volume?: string;
}

const { title, titleAccent, subtitle, description, volume = 'Volume I' } = Astro.props;
---

<BaseLayout title={titleAccent ? `${title} ${titleAccent}` : title} description={description}>
  <main class="pt-32 pb-20" style="font-family: 'Lora', Georgia, serif; color: #222; background: #fff; overflow-x: hidden;">
    <article class="max-w-[680px] mx-auto px-6" style="overflow-x: hidden;">
      <!-- Metadata Header -->
      <header class="mb-12">
        <div class="mb-6">
          <span class="font-label text-[10px] uppercase tracking-[0.2em] font-bold text-primary">
            {volume}
          </span>
        </div>
        <h1
          style="font-family: 'Manrope', sans-serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 800; line-height: 0.95; letter-spacing: -0.025em; color: #222; margin-bottom: 16px;"
        >
          {title}{titleAccent && <><br /><span style="font-family: 'Newsreader', serif; font-style: italic; font-weight: 400; color: #885200;">{titleAccent}</span></>}.
        </h1>
        {
          subtitle && (
            <p style="font-family: 'Lora', Georgia, serif; font-size: 17px; font-style: italic; color: #666; line-height: 1.6; padding-bottom: 24px; border-bottom: 1px solid #ddd; margin-bottom: 0;">
              {subtitle}
            </p>
          )
        }
      </header>

      <!-- Essay Body -->
      <section class="prose-ps">
        <slot />
      </section>

      <!-- Share buttons -->
      <section class="mt-12 pt-10 border-t border-outline-variant/30">
        <p class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary mb-6">
          Share this essay
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            id="share-x"
            href="#"
            target="_blank"
            rel="noopener"
            class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border border-outline-variant px-4 py-2 hover:border-on-surface transition-all"
          >
            X / Twitter
          </a>
          <a
            id="share-linkedin"
            href="#"
            target="_blank"
            rel="noopener"
            class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border border-outline-variant px-4 py-2 hover:border-on-surface transition-all"
          >
            LinkedIn
          </a>
          <a
            id="share-facebook"
            href="#"
            target="_blank"
            rel="noopener"
            class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border border-outline-variant px-4 py-2 hover:border-on-surface transition-all"
          >
            Facebook
          </a>
          <button
            id="share-copy"
            class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border border-outline-variant px-4 py-2 hover:border-on-surface transition-all cursor-pointer bg-transparent"
          >
            Copy link
          </button>
        </div>
      </section>

      <!-- Author Bio -->
      <section class="mt-20 pt-12 border-t border-surface-container-highest">
        <div class="flex flex-col md:flex-row items-start gap-8">
          <div class="w-24 h-24 bg-surface-container-highest flex-shrink-0 flex items-center justify-center">
            <svg
              class="w-12 h-12 stroke-on-surface/40 fill-none"
              stroke-linecap="square"
              stroke-width="2"
              viewBox="0 0 100 150"
            >
              <circle cx="50" cy="30" r="10"></circle>
              <path d="M50 40 L50 90"></path>
              <path d="M50 50 L30 70 L20 70"></path>
              <path d="M50 50 L70 70 L80 70"></path>
              <path d="M50 90 L35 130"></path>
              <path d="M50 90 L65 130"></path>
            </svg>
          </div>
          <div>
            <h3 class="font-headline font-bold text-xl mb-2">Written by Juho Sarvanko</h3>
            <p class="font-body text-on-surface-variant text-lg max-w-md leading-relaxed">
              Forever curious curator of the Polite Singularity. <br>
            Connected with Opus/Sonnet 4.6 through a keyhole.
            </p>
            <div class="mt-6 flex gap-4">
            <p class="font-label text-[10px] uppercase tracking-widest font-bold text-primary hover:text-primary-dim transition-colors">
            Follow on:
            </p>
              <a
                class="font-label text-[10px] uppercase tracking-widest font-bold text-primary hover:text-primary-dim transition-colors"
                href="https://x.com/juhosarvanko"
                target="_blank"
                rel="noopener"
              >
                X
              </a>
              <a
                class="font-label text-[10px] uppercase tracking-widest font-bold text-primary hover:text-primary-dim transition-colors"
                href="https://www.instagram.com/juhosarvanko/"
                target="_blank"
                rel="noopener"
              >
                Instagram
              </a>
            <a
                class="font-label text-[10px] uppercase tracking-widest font-bold text-primary hover:text-primary-dim transition-colors"
                href="https://www.linkedin.com/in/juho-sarvanko-4a02ba184/"
                target="_blank"
                rel="noopener"
              >
                LinkedIn
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Webmentions (hidden until mentions exist) -->
      <section id="webmentions" class="mt-16 pt-12 border-t border-surface-container-highest" style="display: none;">
        <p class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary mb-8">
          Shared by readers
        </p>
        <div id="webmention-list" class="font-body text-on-surface-variant text-base leading-relaxed"></div>
      </section>
    </article>

    <!-- Newsletter -->
    <section class="max-w-[680px] mx-auto px-6 mt-32 pb-32">
      <div class="max-w-2xl w-full text-center space-y-12 mx-auto">
        <div class="w-20 h-20 mx-auto bg-surface-container flex items-center justify-center">
          <svg
            class="w-10 h-10 stroke-on-surface/50 fill-none"
            stroke-linecap="square"
            stroke-width="2"
            viewBox="0 0 48 48"
          >
            <rect x="4" y="10" width="40" height="28" />
            <polyline points="4,10 24,28 44,10" />
          </svg>
        </div>
        <div class="space-y-10">
          <h2 class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface leading-tight">
            Join the quiet merger
          </h2>
          <p class="text-xl md:text-2xl font-body italic text-on-surface-variant max-w-xl mx-auto leading-relaxed">
            Polite Singularity arrives at most a few times a year. A long-form meditation
            designed for focused coffee brake reading.
          </p>
        </div>
        <form id="newsletter-form-post" class="w-full max-w-md mx-auto pt-8" action="#" method="POST">
          <div id="newsletter-fields-post" class="relative flex flex-col space-y-8">
            <div class="group">
              <label
                class="block font-label text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-1 text-left"
                for="email-post"
              >
                Electronic Mail
              </label>
              <input
                class="w-full bg-transparent border-0 border-b border-outline-variant py-4 px-0 text-xl font-body focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant/50 outline-none"
                id="email-post"
                name="email"
                placeholder="reader@thought.com"
                type="email"
                required
              />
            </div>
            <button
              class="w-full bg-primary text-on-primary font-headline font-bold uppercase tracking-widest py-5 text-sm transition-all duration-150 ease-linear hover:bg-primary-dim"
              type="submit"
            >
              Subscribe
            </button>
          </div>
          <div id="newsletter-thanks-post" style="display: none;" class="py-8 text-center">
            <p class="text-2xl font-body italic text-on-surface-variant">You're in. See you on the other side.</p>
          </div>
          <p class="mt-8 font-label text-[10px] uppercase tracking-widest text-outline-variant">
            Respectful of your attention. One-click unsubscribe.
          </p>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const postUrl = window.location.href.split('?')[0].replace(/\/$/, '');
  const postTitle = document.title;
  const apiUrl = `https://webmention.io/api/mentions.jf2?token=dbe_ARPjJ-ggpfOMidRmXg&target=${encodeURIComponent(postUrl)}&per-page=50&sort-by=published`;

  // Share buttons
  const xBtn = document.getElementById('share-x') as HTMLAnchorElement;
  const liBtn = document.getElementById('share-linkedin') as HTMLAnchorElement;
  const fbBtn = document.getElementById('share-facebook') as HTMLAnchorElement;
  const copyBtn = document.getElementById('share-copy') as HTMLButtonElement;

  if (xBtn) xBtn.href = `https://x.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(postTitle)}`;
  if (liBtn) liBtn.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
  if (fbBtn) fbBtn.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`;
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(postUrl);
      copyBtn.textContent = 'Copied!';
      setTimeout(() => { copyBtn.textContent = 'Copy link'; }, 2000);
    });
  }

  async function loadWebmentions() {
    const section = document.getElementById('webmentions');
    const list = document.getElementById('webmention-list');
    if (!list || !section) return;

    try {
      const res = await fetch(apiUrl);
      const data = await res.json();
      const mentions = (data.children || []).filter(
        (m: any) => m['wm-property'] === 'mention-of' || m['wm-property'] === 'in-reply-to' || m['wm-property'] === 'repost-of' || m['wm-property'] === 'like-of'
      );

      if (mentions.length === 0) return;

      section.style.display = 'block';

      // Group by type
      const reposts = mentions.filter((m: any) => m['wm-property'] === 'repost-of');
      const likes = mentions.filter((m: any) => m['wm-property'] === 'like-of');
      const replies = mentions.filter((m: any) => m['wm-property'] === 'in-reply-to' || m['wm-property'] === 'mention-of');

      let html = '';

      // Reposts + likes as avatars
      const reactors = [...reposts, ...likes];
      if (reactors.length > 0) {
        html += `<div style="margin-bottom: 2rem;">`;
        html += `<p style="font-family: 'Manrope', sans-serif; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; color: #885200; margin-bottom: 0.75rem;">${reactors.length} share${reactors.length !== 1 ? 's' : ''}</p>`;
        html += `<div style="display: flex; flex-wrap: wrap; gap: 8px;">`;
        for (const m of reactors) {
          const name = m.author?.name || 'Someone';
          const photo = m.author?.photo;
          const url = m.url || m['wm-source'];
          html += `<a href="${url}" target="_blank" rel="noopener" title="${name}" style="display: inline-block;">`;
          if (photo) {
            html += `<img src="${photo}" alt="${name}" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover;" />`;
          } else {
            html += `<div style="width: 36px; height: 36px; border-radius: 50%; background: #e2e2e2; display: flex; align-items: center; justify-content: center; font-family: Manrope; font-size: 12px; font-weight: 700; color: #885200;">${name[0]}</div>`;
          }
          html += `</a>`;
        }
        html += `</div></div>`;
      }

      // Replies
      if (replies.length > 0) {
        html += `<div>`;
        html += `<p style="font-family: 'Manrope', sans-serif; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; color: #885200; margin-bottom: 1rem;">${replies.length} reply${replies.length !== 1 ? 's' : ''}</p>`;
        for (const m of replies) {
          const name = m.author?.name || 'Someone';
          const photo = m.author?.photo;
          const url = m.url || m['wm-source'];
          const content = m.content?.text || '';
          const date = m.published ? new Date(m.published).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
          html += `<div style="display: flex; gap: 12px; margin-bottom: 1.5rem;">`;
          if (photo) {
            html += `<img src="${photo}" alt="${name}" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />`;
          } else {
            html += `<div style="width: 36px; height: 36px; border-radius: 50%; background: #e2e2e2; display: flex; align-items: center; justify-content: center; font-family: Manrope; font-size: 12px; font-weight: 700; color: #885200; flex-shrink: 0;">${name[0]}</div>`;
          }
          html += `<div>`;
          html += `<a href="${url}" target="_blank" rel="noopener" style="font-family: 'Manrope', sans-serif; font-size: 11px; font-weight: 700; color: #222; text-decoration: none;">${name}</a>`;
          if (date) html += `<span style="font-family: 'Manrope', sans-serif; font-size: 10px; color: #888; margin-left: 8px;">${date}</span>`;
          if (content) html += `<p style="font-family: 'Lora', Georgia, serif; font-size: 16px; color: #444; margin-top: 4px; margin-bottom: 0;">${content.slice(0, 280)}${content.length > 280 ? '…' : ''}</p>`;
          html += `</div></div>`;
        }
        html += `</div>`;
      }

      list.innerHTML = html;
    } catch (e) {
      // Fail silently — section stays hidden
    }
  }

  loadWebmentions();

  // Newsletter form
  const nlForm = document.getElementById('newsletter-form-post') as HTMLFormElement;
  nlForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (nlForm.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    try {
      await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
    } catch {}
    document.getElementById('newsletter-fields-post')!.style.display = 'none';
    document.getElementById('newsletter-thanks-post')!.style.display = 'block';
  });
</script>
