---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Newsletter"
  description="Essays on tech and consciousness, delivered once a month. No noise, just signal."
  activeTab="newsletter"
>
  <main class="min-h-screen pt-40 pb-20 px-6 flex flex-col items-center justify-center">
    <div class="max-w-2xl w-full text-center space-y-12">

      <!-- Envelope illustration (inline SVG, no external deps) -->
      <div class="w-20 h-20 mx-auto bg-surface-container flex items-center justify-center">
        <svg
          class="w-10 h-10 stroke-on-surface/50 fill-none"
          stroke-linecap="square"
          stroke-width="2"
          viewBox="0 0 48 48"
        >
          <!-- Envelope body -->
          <rect x="4" y="10" width="40" height="28" />
          <!-- Envelope flap -->
          <polyline points="4,10 24,28 44,10" />
        </svg>
      </div>

      <!-- Heading -->
      <div class="space-y-4">
        <h1
          class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface leading-tight"
        >
          Join the quiet merger
        </h1>
        <p
          class="text-xl md:text-2xl font-body italic text-on-surface-variant max-w-xl mx-auto leading-relaxed"
        >
          Essays on tech and consciousness, delivered to your thinking space once a month.
          No noise, just signal.
        </p>
      </div>

      <!-- Form -->
      <form class="w-full max-w-md mx-auto pt-8" action="#" method="POST">
        <div class="relative flex flex-col space-y-8">
          <div class="group">
            <label
              class="block font-label text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-1 text-left"
              for="email"
            >
              Electronic Mail
            </label>
            <input
              class="w-full bg-transparent border-0 border-b border-outline-variant py-4 px-0 text-xl font-body focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant/50 outline-none"
              id="email"
              name="email"
              placeholder="reader@thought.com"
              type="email"
              required
            />
          </div>
          <button
            class="w-full bg-primary text-on-primary font-headline font-bold uppercase tracking-widest py-5 text-sm transition-all duration-150 ease-linear hover:bg-primary-dim"
            type="submit"
          >
            Subscribe
          </button>
        </div>
        <p class="mt-8 font-label text-[10px] uppercase tracking-widest text-outline-variant">
          Respectful of your attention. One-click unsubscribe.
        </p>
      </form>

      <!-- Details -->
      <div
        class="pt-20 grid grid-cols-1 md:grid-cols-2 gap-12 text-left max-w-3xl mx-auto border-t border-outline-variant/30"
      >
        <div class="space-y-3">
          <span class="font-label text-[11px] font-bold uppercase tracking-widest text-primary">
            01. The Frequency
          </span>
          <p class="font-body text-on-surface-variant">
            The Polite Singularity arrives at most once a month. It is a long-form meditation
            designed for focused weekend reading.
          </p>
        </div>
        <div class="space-y-3">
          <span class="font-label text-[11px] font-bold uppercase tracking-widest text-primary">
            02. The Content
          </span>
          <p class="font-body text-on-surface-variant">
            Original synthesis of artificial intelligence, digital philosophy, and the future of
            human awareness. No curation, only creation.
          </p>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
