---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: '2-digit',
  });
}
---

<BaseLayout title="Home" isHomePage={true}>
  <!-- HOME -->
  <section
    id="home"
    class="min-h-screen relative overflow-hidden flex flex-col justify-center"
  >
    <!-- Background illustration -->
    <img
      src="/images/staircase.png"
      alt=""
      class="absolute pointer-events-none select-none hidden md:block"
      style="width: 80%; height: auto; right: 0.5; top: 8;"
    />

    <!-- Text -->
    <div class="relative z-10 px-8 max-w-4xl mx-auto w-full">
      <header>
        <p class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary mb-4">
          Welcome to the
        </p>
        <h1
          class="text-6xl md:text-8xl font-headline font-extrabold tracking-tight text-on-surface leading-[0.95] mb-8"
        >
          Polite <br />Singularity.
        </h1>
      </header>
      <div class="min-h-[8rem]"></div>
    </div>
  </section>

  <!-- ABOUT / ARCHITECT'S INTENT -->
  <section id="intent" class="max-w-4xl mx-auto px-8 py-32 pb-64" style="scroll-margin-top: 80px;">
    <div class="max-w-2xl intent-offset">
      <p class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary mb-8">
        The Architect's Intent
      </p>
      <div class="font-body text-[19px] leading-[1.75] text-on-surface space-y-6">
        <p>
          Through this archive, I explore the intersections of consciousness, information
          and energy. In all of its magnificent, cosmic, gritty glory.
        </p>
        <p>
          I write about things that have taken form and things that have not made it that
          far from the void of infinite potential yet. Whatever climbs far enough up the priority queue of my
          brain to demand 5,000 words of attention. Seen through the lens of a dad, a
          self-made mystic and a self-made goof. In an attempt to crystallise ideas from
          the aether, that promote neuroplasticity, intelligence expansion and occasional chuckels.
        </p>
        <p>
          If you find value in these contemplations, I invite you to join the newsletter.
          It is a digital monograph delivered to your inbox, written in the form of
          long-form meditations to counter balance the instant gratification loop of the
          infinite scroll.
        </p>
        <p>
          While we keep ascending to the heavens, some of the stairs were left squeaky on purpose.
        </p>
      </div>
    </div>
  </section>

  <!-- ARCHIVE -->
  <section
    id="archive"
    class="min-h-screen flex flex-col justify-start pt-36 pb-64 px-8 max-w-4xl mx-auto"
    style="scroll-margin-top: 80px;"
  >
    <header class="mb-24">
      <div class="mb-4">
        <span class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary">
          Volume I
        </span>
      </div>
      <h2
        class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface mb-8 leading-[0.9]"
      >
        AI: Humanity's<br /><span class="font-body italic font-normal text-primary">Last Tool</span>.
      </h2>
      <p class="max-w-xl text-xl text-on-surface-variant leading-relaxed mb-8">
        The age of tools as purely external, dumb, inert things is ending. What comes next
        doesn't stay outside. It's learning to think with you.
      </p>
      <a
        href="/posts/ai-humanitys-last-tool"
        class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border-b border-on-surface pb-1 hover:text-primary hover:border-primary transition-all"
      >
        Read Essay
      </a>
    </header>
  </section>

  <!-- NEWSLETTER -->
  <section
    id="newsletter"
    class="min-h-screen flex flex-col justify-center px-6 max-w-4xl mx-auto"
    style="scroll-margin-top: 80px;"
  >
    <div class="max-w-2xl w-full text-center space-y-12 mx-auto">
      <!-- Envelope illustration -->
      <div class="w-20 h-20 mx-auto bg-surface-container flex items-center justify-center">
        <svg
          class="w-10 h-10 stroke-on-surface/50 fill-none"
          stroke-linecap="square"
          stroke-width="2"
          viewBox="0 0 48 48"
        >
          <rect x="4" y="10" width="40" height="28" />
          <polyline points="4,10 24,28 44,10" />
        </svg>
      </div>

      <div class="space-y-10">
        <h2
          class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface leading-tight"
        >
          Join the quiet merger
        </h2>
        <p
          class="text-xl md:text-2xl font-body italic text-on-surface-variant max-w-xl mx-auto leading-relaxed"
        >
          Polite Singularity arrives at most a few times a year. A long-form meditation
          designed for focused coffee brake reading.
        </p>
      </div>

      <form id="newsletter-form-home" class="w-full max-w-md mx-auto pt-8" action="#" method="POST" data-netlify="true" name="newsletter">
        <div id="newsletter-fields-home" class="relative flex flex-col space-y-8">
          <div class="group">
            <label
              class="block font-label text-[10px] uppercase tracking-[0.2em] font-bold text-outline mb-1 text-left"
              for="email"
            >
              Electronic Mail
            </label>
            <input
              class="w-full bg-transparent border-0 border-b border-outline-variant py-4 px-0 text-xl font-body focus:ring-0 focus:border-primary transition-all placeholder:text-outline-variant/50 outline-none"
              id="email"
              name="email"
              placeholder="reader@thought.com"
              type="email"
              required
            />
          </div>
          <button
            class="w-full bg-primary text-on-primary font-headline font-bold uppercase tracking-widest py-5 text-sm transition-all duration-150 ease-linear hover:bg-primary-dim"
            type="submit"
          >
            Subscribe
          </button>
        </div>
        <div id="newsletter-thanks-home" style="display: none;" class="py-8 text-center">
          <p class="text-2xl font-body italic text-on-surface-variant">You're in. See you on the other side.</p>
        </div>
        <p class="mt-8 font-label text-[10px] uppercase tracking-widest text-outline-variant">
          Respectful of your attention. One-click unsubscribe.
        </p>
      </form>

    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('newsletter-form-home') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[type="email"]') as HTMLInputElement)?.value;
    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ 'form-name': 'newsletter', email }).toString(),
      });
    } catch {}
    document.getElementById('newsletter-fields-home')!.style.display = 'none';
    document.getElementById('newsletter-thanks-home')!.style.display = 'block';
  });
</script>
