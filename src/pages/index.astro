---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Home" activeTab="home">
  <main class="pt-40 pb-20 px-8 max-w-4xl mx-auto">
    <!-- Title -->
    <header class="mb-32">
      <h1
        class="text-6xl md:text-8xl font-headline font-extrabold tracking-tight text-on-surface leading-[0.95]"
      >
        Polite Singularity.
      </h1>
    </header>

    <!-- Essays -->
    <section>
      <h2 class="text-center font-label uppercase tracking-[0.2em] text-[11px] font-bold text-outline mb-16">
        Essays
      </h2>
      <ul class="space-y-10 text-center">
        {posts.map((post) => (
          <li>
            <a
              href={`/posts/${post.id}`}
              class="font-body text-2xl md:text-3xl text-on-surface hover:text-primary transition-colors duration-150"
            >
              {post.data.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>
