---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: '2-digit',
  });
}
---

<BaseLayout title="Archive" activeTab="archive">
  <main class="pt-32 pb-20 px-8 max-w-4xl mx-auto">
    <!-- Editorial Header -->
    <header class="mb-24">
      <div class="mb-4">
        <span class="font-label uppercase tracking-[0.2em] text-[10px] font-bold text-primary">
          Volume I
        </span>
      </div>
      <h1
        class="text-5xl md:text-7xl font-headline font-extrabold tracking-tight text-on-surface mb-8 leading-[0.9]"
      >
        Archive of Thoughtful <span class="font-body italic font-normal text-primary"
          >Inquiries</span
        >.
      </h1>
      <p class="max-w-xl text-xl text-on-surface-variant leading-relaxed">
        A collection of long-form essays exploring the intersection of technology, humanism, and the
        quiet dignity of the analog world.
      </p>
    </header>

    <!-- Essay List -->
    <section class="space-y-24">
      {
        posts.map((post) => (
          <article class="group max-w-2xl">
            <div class="mb-3 flex items-center gap-4">
              <time class="font-label uppercase tracking-widest text-[10px] font-bold text-outline">
                {formatDate(post.data.date)}
              </time>
              <span class="h-px w-8 bg-outline-variant" />
              <span class="font-label uppercase tracking-widest text-[10px] font-bold text-primary">
                {post.data.category}
              </span>
            </div>
            <h2 class="text-3xl md:text-4xl font-body font-bold mb-4 group-hover:text-primary transition-colors duration-200">
              <a href={`/posts/${post.id}`}>{post.data.title}</a>
            </h2>
            <p class="text-lg text-on-surface-variant leading-relaxed mb-6">
              {post.data.description}
            </p>
            <a
              href={`/posts/${post.id}`}
              class="font-label uppercase tracking-widest text-[11px] font-bold text-on-surface border-b border-on-surface pb-1 hover:text-primary hover:border-primary transition-all"
            >
              Read Essay
            </a>
          </article>
        ))
      }
    </section>

    {
      posts.length === 0 && (
        <div class="text-center py-20">
          <p class="text-xl text-on-surface-variant font-body italic">
            The archive is being prepared. First essays arriving soon.
          </p>
        </div>
      )
    }
  </main>
</BaseLayout>
