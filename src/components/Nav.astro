---
interface Props {
  isHomePage?: boolean;
}

const { isHomePage = false } = Astro.props;

const navItems = [
  { label: 'Home',       anchor: 'home' },
  { label: 'Intent',     anchor: 'intent' },
  { label: 'Archive',    anchor: 'archive' },
  { label: 'Newsletter', anchor: 'newsletter' },
];
---

<header class="fixed top-0 w-full z-50 backdrop-blur-md bg-white/90">
  <nav class="flex justify-between items-center w-full px-8 py-6 max-w-7xl mx-auto">
    <a href="/" class="text-lg font-bold tracking-tighter text-stone-800 font-headline">
      Polite Singularity
    </a>

    <div class="hidden md:flex gap-8 items-center">
      {navItems.map((item) => (
        <a
          href={isHomePage ? `#${item.anchor}` : `/#${item.anchor}`}
          data-section={item.anchor}
          class:list={[
            "nav-link font-['Manrope'] uppercase tracking-widest text-[11px] font-semibold transition-all duration-150 ease-linear",
            "text-stone-500 hover:text-stone-800",
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-stone-800">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-md px-8 pb-8 space-y-6">
    {navItems.map((item) => (
      <a
        href={isHomePage ? `#${item.anchor}` : `/#${item.anchor}`}
        data-section={item.anchor}
        class="mobile-nav-link block font-['Manrope'] uppercase tracking-widest text-[11px] font-semibold text-stone-500"
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
    });
  });

  // Scroll-spy: highlight active section in nav
  const sections = ['home', 'intent', 'archive', 'newsletter']
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  if (sections.length > 0) {
    function setActive(id: string) {
      document.querySelectorAll('.nav-link').forEach((link) => {
        const section = link.getAttribute('data-section');
        if (section === id) {
          link.classList.add('text-amber-800', 'border-b-2', 'border-amber-800', 'pb-1');
          link.classList.remove('text-stone-500');
        } else {
          link.classList.remove('text-amber-800', 'border-b-2', 'border-amber-800', 'pb-1');
          link.classList.add('text-stone-500');
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        // Pick the entry that is most visible
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      { threshold: 0.4 }
    );

    sections.forEach((s) => observer.observe(s));

    // Set initial active state on page load
    setActive('home');
  }
</script>
