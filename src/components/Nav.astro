---
interface Props {
  activeTab?: 'home' | 'archive' | 'newsletter';
}

const { activeTab = 'home' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', id: 'home' as const },
  { href: '/archive', label: 'Archive', id: 'archive' as const },
  { href: '/newsletter', label: 'Newsletter', id: 'newsletter' as const },
];

function isActive(id: string) {
  return id === activeTab;
}
---

<header class="fixed top-0 w-full z-50 backdrop-blur-md bg-stone-50/80">
  <nav class="flex justify-between items-center w-full px-8 py-6 max-w-7xl mx-auto">
    <a href="/" class="text-lg font-bold tracking-tighter text-stone-800 font-headline">
      Polite Singularity
    </a>

    <div class="hidden md:flex gap-8 items-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "font-['Manrope'] uppercase tracking-widest text-[11px] font-semibold transition-all duration-150 ease-linear",
            isActive(item.id)
              ? 'text-amber-800 border-b-2 border-amber-800 pb-1'
              : 'text-stone-500 hover:text-stone-800',
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden text-stone-800">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-stone-50/95 backdrop-blur-md px-8 pb-8 space-y-6">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={[
          "block font-['Manrope'] uppercase tracking-widest text-[11px] font-semibold",
          isActive(item.id) ? 'text-amber-800' : 'text-stone-500',
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
